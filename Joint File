ols_season <- function(x, Y, label) {
  n_r  <- length(Y)
  xbar <- sum(x) / n_r
  Ybar <- sum(Y) / n_r
  Sxx  <- sum((x - xbar)^2)
  SxY  <- sum((x - xbar) * (Y - Ybar))
  b    <- SxY / Sxx
  a    <- Ybar - b * xbar
  eps  <- Y - a - b * x
  S2   <- sum(eps^2) / (n_r - 2)
  se_b <- sqrt(S2 / Sxx)
  t_b  <- b / se_b
  p_b  <- 1 - pt(t_b, df = n_r - 2)
  t_cv <- qt(0.975, df = n_r - 2)
  ci   <- c(b - t_cv * se_b, b + t_cv * se_b)
  list(b = b, se = se_b, t = t_b, p = p_b, S2 = S2, ci = ci,
       a = a, eps = eps, n = n_r)
}

ols_season_partial <- function(x, Y, bp, label) {
  n_r  <- length(Y)
  xp   <- ifelse(x >= bp, x - bp, 0)
  xbar <- sum(xp) / n_r
  Ybar <- sum(Y) / n_r
  Sxx  <- sum((xp - xbar)^2)
  SxY  <- sum((xp - xbar) * (Y - Ybar))
  b    <- SxY / Sxx
  a    <- Ybar - b * xbar
  eps  <- Y - a - b * xp
  S2   <- sum(eps^2) / (n_r - 2)
  se_b <- sqrt(S2 / Sxx)
  t_b  <- b / se_b
  p_b  <- 1 - pt(t_b, df = n_r - 2)
  t_cv <- qt(0.975, df = n_r - 2)
  ci   <- c(b - t_cv * se_b, b + t_cv * se_b)
  list(b = b, se = se_b, t = t_b, p = p_b, S2 = S2, ci = ci,
       a = a, eps = eps, n = n_r, xp = xp)
}

