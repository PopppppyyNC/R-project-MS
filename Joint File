# sensitivity to breakpoint choice

bp_values <- c(1960, 1965, 1970, 1975, 1980, 1985, 1990)

bp_results <- data.frame(Breakpoint = integer(), Beta = numeric(),
                         SE = numeric(), t_stat = numeric(),
                         p_value = numeric(), RSS = numeric(),
                         alpha_hat = numeric())

for (bp in bp_values) {
  x_bp     <- ifelse(years >= bp, years - bp, 0)
  xbar_bp  <- sample_mean(x_bp)
  Sxx_bp   <- sum((x_bp - xbar_bp)^2)
  SxY_bp   <- sum((x_bp - xbar_bp) * (Y - Ybar))
  bLS_bp   <- SxY_bp / Sxx_bp
  aLS_bp   <- Ybar - bLS_bp * xbar_bp
  RSS_bp   <- sum((Y - aLS_bp - bLS_bp * x_bp)^2)
  S2_bp    <- RSS_bp / (n - 2)
  se_bp    <- sqrt(S2_bp / Sxx_bp)
  t_bp     <- bLS_bp / se_bp
  p_bp     <- 1 - pt(t_bp, df = n - 2)
  
  bp_results <- rbind(bp_results,
                      data.frame(Breakpoint = bp, Beta = bLS_bp, SE = se_bp,
                                 t_stat = t_bp, p_value = p_bp, RSS = RSS_bp,
                                 alpha_hat = aLS_bp))
}

bp_results$CI_lower <- bp_results$Beta - t_cv * bp_results$SE
bp_results$CI_upper <- bp_results$Beta + t_cv * bp_results$SE

