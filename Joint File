run_ols <- function(x, Y, label) {
  n_r  <- length(Y)
  xbar <- sample_mean(x)
  Ybar <- sample_mean(Y)
  Sxx  <- sum((x - xbar)^2)
  SxY  <- sum((x - xbar) * (Y - Ybar))
  bLS  <- SxY / Sxx
  aLS  <- Ybar - bLS * xbar
  eps  <- Y - aLS - bLS * x
  S2   <- sum(eps^2) / (n_r - 2)
  se_b <- sqrt(S2 / Sxx)
  t_b  <- bLS / se_b
  p_b  <- 1 - pt(t_b, df = n_r - 2)
  cat(sprintf("  %s: bLS = %.6f, SE = %.6f, t = %.4f, p (1s) = %s\n",
              label, bLS, se_b, t_b, format(p_b, scientific = TRUE, digits = 4)))
  list(bLS = bLS, se = se_b, t = t_b, p = p_b, S2 = S2, eps = eps)
}

