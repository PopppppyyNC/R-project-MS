gamma_0_part <- sum(eps_part^2) / n
rho_part     <- rep(0, max_lag)
for (h in 1:max_lag) {
  rho_part[h] <- sum(eps_part[1:(n - h)] * eps_part[(1 + h):n]) / (n * gamma_0_part)
}

