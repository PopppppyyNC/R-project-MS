  flag_p <- ifelse(abs(rho_part[h]) > band, " ***", "")
  cat(sprintf("  rho_hat(%2d) %10.4f%-4s %10.4f%-4s\n",
              h, rho_hat[h], flag_f, rho_part[h], flag_p))
}

