# (5) rolling 30-year window

rolling_ci <- function(x, yrs, w) {
  n_windows <- length(x) - w + 1
  mid   <- numeric(n_windows)
  means <- numeric(n_windows)
  lo    <- numeric(n_windows)
  hi    <- numeric(n_windows)
  for (i in 1:n_windows) {
    xi       <- x[i:(i + w - 1)]
    ci       <- ci_mean(xi)
    mid[i]   <- yrs[i] + (w - 1) / 2
    means[i] <- ci$mean
    lo[i]    <- ci$lower
    hi[i]    <- ci$upper
  }
  data.frame(mid = mid, mean = means, lower = lo, upper = hi)
}

