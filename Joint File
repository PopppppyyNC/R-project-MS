  labs(title = "Estimated Post-Breakpoint Slope Across Different Breakpoints",
       x = "Breakpoint Year", y = expression(hat(beta))) +
  theme_minimal()

# robustness across stations

run_partial_ols <- function(years, Y, bp, label) {
  n_r      <- length(Y)
  x_bp     <- ifelse(years >= bp, years - bp, 0)
  Ybar_r   <- sample_mean(Y)
  xbar_bp  <- sample_mean(x_bp)
  Sxx_bp   <- sum((x_bp - xbar_bp)^2)
  SxY_bp   <- sum((x_bp - xbar_bp) * (Y - Ybar_r))
  bLS_bp   <- SxY_bp / Sxx_bp
  aLS_bp   <- Ybar_r - bLS_bp * xbar_bp
  eps_bp   <- Y - aLS_bp - bLS_bp * x_bp
  S2_bp    <- sum(eps_bp^2) / (n_r - 2)
  se_bp    <- sqrt(S2_bp / Sxx_bp)
  t_bp     <- bLS_bp / se_bp
  p_bp     <- 1 - pt(t_bp, df = n_r - 2)
  cat(sprintf("  %s: bLS = %.6f, SE = %.6f, t = %.4f, p(1s) = %s, alpha = %.4f\n",
              label, bLS_bp, se_bp, t_bp,
              format(p_bp, scientific = TRUE, digits = 4), aLS_bp))
}

cat("\n=== Robustness: Partial Trend from", breakpoint, "===\n")
run_partial_ols(years, maastricht, breakpoint, "Maastricht")
run_partial_ols(years, de_bilt,    breakpoint, "De Bilt")
run_partial_ols(years, eelde,      breakpoint, "Eelde")

